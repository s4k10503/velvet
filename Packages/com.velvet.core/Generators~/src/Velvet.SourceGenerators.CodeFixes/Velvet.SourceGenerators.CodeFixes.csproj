<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <RootNamespace>Velvet.SourceGenerators.CodeFixes</RootNamespace>
    <AssemblyName>Velvet.SourceGenerators.CodeFixes</AssemblyName>
    <Version>0.1.0</Version>
    <Authors>s4k10503</Authors>
    <Description>Roslyn Code Fix Providers for the Velvet Unity package.</Description>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <!-- Match Unity 6's Roslyn host (4.3.0). 4.8.0 raises CS9057 and breaks the loader. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.3.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Velvet.SourceGenerators\Velvet.SourceGenerators.csproj" PrivateAssets="all" />
  </ItemGroup>

</Project>
