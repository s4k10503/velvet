.basis-16 { flex-basis: var(--space-16); }
.basis-20 { flex-basis: var(--space-20); }
.basis-24 { flex-basis: var(--space-24); }
.basis-28 { flex-basis: var(--space-28); }
.basis-32 { flex-basis: var(--space-32); }
.basis-36 { flex-basis: var(--space-36); }
.basis-40 { flex-basis: var(--space-40); }
.basis-44 { flex-basis: var(--space-44); }
.basis-48 { flex-basis: var(--space-48); }
.basis-52 { flex-basis: var(--space-52); }
.basis-56 { flex-basis: var(--space-56); }
.basis-60 { flex-basis: var(--space-60); }
.basis-64 { flex-basis: var(--space-64); }
.basis-72 { flex-basis: var(--space-72); }
.basis-80 { flex-basis: var(--space-80); }
.basis-96 { flex-basis: var(--space-96); }
.basis-auto { flex-basis: auto; }
.basis-full { flex-basis: 100%; }

/* Overflow */
.overflow-hidden { overflow: hidden; }
.overflow-visible { overflow: visible; }

/* Inset (all edges) */
