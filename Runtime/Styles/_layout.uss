/* Layout Utilities - display, position, flex, overflow, inset */

/*
 * Display
 *
 * NOTE (Tailwind parity): in CSS/Tailwind `flex` implies `flex-direction: row`,
 * but UI Toolkit's layout engine (Yoga) defaults a flex container to `column`.
 * `.flex` therefore sets `flex-direction: row` explicitly so a bare `flex` lays
 * children out HORIZONTALLY, matching Tailwind. Override the direction with:
 *   - horizontal row : "flex" (or the redundant "flex flex-row")
 *   - vertical column: "flex flex-col"
 * See Documentation~/styling-flexbox-and-gap.md.
 */
.flex { display: flex; flex-direction: row; }
/*
 * NOTE (Tailwind parity): UI Toolkit has no `display: grid` (its layout is a Flexbox subset), so `.grid`
 * is realized as a flex-wrap row and StyleGridManipulator sizes the children into the grid-cols-N columns
 * (and owns the gap-* spacing). A bare `grid` with no grid-cols-N is a single column (the manipulator sizes
 * each child to the full row, stacking them vertically). See Documentation~/styling-flexbox-and-gap.md.
 */
.grid { display: flex; flex-direction: row; flex-wrap: wrap; }
.hidden { display: none; }

/* Position */
.relative { position: relative; }
.absolute { position: absolute; }

/* Flex Direction */
.flex-row { flex-direction: row; }
.flex-col { flex-direction: column; }

/* Flex Wrap */
.flex-wrap { flex-wrap: wrap; }
.flex-nowrap { flex-wrap: nowrap; }

/* Flex Direction (reverse) */
.flex-row-reverse { flex-direction: row-reverse; }
.flex-col-reverse { flex-direction: column-reverse; }

/* Flex Wrap (reverse) */
.flex-wrap-reverse { flex-wrap: wrap-reverse; }

/* Align Items (cross axis) */
.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.items-stretch { align-items: stretch; }
.items-baseline { align-items: baseline; }

/* Align Self */
.self-auto { align-self: auto; }
.self-start { align-self: flex-start; }
.self-center { align-self: center; }
.self-end { align-self: flex-end; }
.self-stretch { align-self: stretch; }

/* Align Content (multi-line cross axis).
   Note: Unity's `align-content` uses the `Align` enum, which (unlike CSS) has no
   space-between / space-around — only these keywords are valid. */
.content-start { align-content: flex-start; }
.content-center { align-content: center; }
.content-end { align-content: flex-end; }
.content-stretch { align-content: stretch; }

/* Justify Content (main axis) */
.justify-start { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-evenly { justify-content: space-evenly; }

/* Flex Grow/Shrink */
.grow { flex-grow: 1; }
.grow-0 { flex-grow: 0; }
.shrink { flex-shrink: 1; }
.shrink-0 { flex-shrink: 0; }

/* Flex shorthand (grow / shrink / basis) */
.flex-1 { flex-grow: 1; flex-shrink: 1; flex-basis: 0; }
.flex-auto { flex-grow: 1; flex-shrink: 1; flex-basis: auto; }
.flex-initial { flex-grow: 0; flex-shrink: 1; flex-basis: auto; }
.flex-none { flex-grow: 0; flex-shrink: 0; flex-basis: auto; }

/* Flex Basis (presets; reuse --space-* tokens. basis-[..] arbitrary covers other values) */
.basis-0 { flex-basis: var(--space-0); }
.basis-px { flex-basis: var(--space-px); }
.basis-0-5 { flex-basis: var(--space-0-5); }
.basis-1 { flex-basis: var(--space-1); }
.basis-1-5 { flex-basis: var(--space-1-5); }
.basis-2 { flex-basis: var(--space-2); }
.basis-2-5 { flex-basis: var(--space-2-5); }
.basis-3 { flex-basis: var(--space-3); }
.basis-3-5 { flex-basis: var(--space-3-5); }
.basis-4 { flex-basis: var(--space-4); }
.basis-5 { flex-basis: var(--space-5); }
.basis-6 { flex-basis: var(--space-6); }
.basis-7 { flex-basis: var(--space-7); }
.basis-8 { flex-basis: var(--space-8); }
.basis-9 { flex-basis: var(--space-9); }
.basis-10 { flex-basis: var(--space-10); }
.basis-11 { flex-basis: var(--space-11); }
.basis-12 { flex-basis: var(--space-12); }
